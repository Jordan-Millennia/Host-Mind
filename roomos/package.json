{
  "name": "roomos",
  "version": "0.1.0",
  "private": true,
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "pnpm --filter @roomos/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @roomos/db prisma generate",
    "db:migrate": "pnpm --filter @roomos/db prisma migrate dev",
    "db:migrate:deploy": "pnpm --filter @roomos/db prisma migrate deploy",
    "db:seed": "pnpm --filter @roomos/db prisma db seed",
    "db:studio": "pnpm --filter @roomos/db prisma studio"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@10.0.0"
}
